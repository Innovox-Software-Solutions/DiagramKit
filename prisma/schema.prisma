// This is your Prisma schema file for MongoDB

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  boards        Board[]
  documents     Document[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Board {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  shapes    Json?
  shapesCompressed String? @db.String
  userId    String?  @db.ObjectId
  shareId   String?
  isPublic  Boolean? @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}

model Document {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  contentHtml String?  @db.String
  userId      String   @db.ObjectId
  shareId     String?
  isPublic    Boolean? @default(false)
  shareLocked Boolean? @default(false)
  sharePassHash String? @db.String
  shareOneTime Boolean? @default(false)
  shareViewCount Int? @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareViews  DocumentShareView[]

  @@index([userId])
  @@index([shareId])
}

model DocumentShareView {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  documentId String   @db.ObjectId
  shareId    String
  viewerId   String
  viewedAt   DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([shareId])
  @@unique([shareId, viewerId])
}

model GuestDocumentShare {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  shareId       String   @unique
  title         String
  contentHtml   String?  @db.String
  shareLocked   Boolean? @default(false)
  sharePassHash String?  @db.String
  shareOneTime  Boolean? @default(false)
  shareViewCount Int?    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         GuestDocumentShareView[]
}

model GuestDocumentShareView {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  shareId  String
  viewerId String
  viewedAt DateTime @default(now())
  share    GuestDocumentShare @relation(fields: [shareId], references: [shareId], onDelete: Cascade)

  @@index([shareId])
  @@unique([shareId, viewerId])
}
